# Rhymes & Poetry — SEO Optimizer Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Anthropic ──────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail ──────────────────────────────────────────────────────────────────
# This is NOT your Gmail login password.
# It's a 16-character App Password generated at:
#   Google Account → Security → 2-Step Verification → App Passwords
#   (2FA must be enabled first)
#   Name the app something like "R&P SEO Optimizer"
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Email addresses ────────────────────────────────────────────────────────
GMAIL_FROM=jakethomasc28@gmail.com
GMAIL_TO=jakethomasc28@gmail.com

# ── Astro blog content directory ───────────────────────────────────────────
# Relative to repo root (where you run the script from)
BLOG_DIR=src/content/blog
