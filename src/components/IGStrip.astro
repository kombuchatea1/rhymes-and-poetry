---
/* ===========================================================================
 * src/components/IGStrip.astro
 * Rhymes & Poetry — Instagram strip
 *
 * Tiles served from /public/images/instagram/ — raw static assets,
 * bypass Astro's image pipeline entirely. Each tile shows an actual
 * IG-format poem image and links to the @rhymesandpoetry_jtc profile.
 *
 * UPDATING THE FEED
 * -----------------
 * 1. Save your IG-format JPG to public/images/instagram/<filename>.jpg
 * 2. Add the path to the IG_TILES array below (newest first)
 * 3. Keep the array at 6 items (drop the oldest when adding a newer one)
 *
 * Future automation: a small build script could glob public/images/
 * instagram/ and emit IG_TILES into a generated TS file. For 6 entries
 * it's not worth the complexity yet.
 * ========================================================================= */

const IG_HANDLE = "rhymesandpoetry_jtc";
const IG_URL = `https://www.instagram.com/${IG_HANDLE}/`;

// Hardcoded list — newest first by IG media ID. Update when adding posts.
const IG_TILES = [
	"/images/instagram/18467476624076623.jpg",
	"/images/instagram/18369520690064438.jpg",
	"/images/instagram/18351214732243229.jpg",
	"/images/instagram/18324093763191048.jpg",
	"/images/instagram/18290795590195979.jpg",
	"/images/instagram/18286288396217610.jpg",
];
---

<section class="ig" aria-labelledby="ig-heading">
	<div class="container">
		<header class="section-header">
			<div>
				<p class="eyebrow">From the feed</p>
				<h2 id="ig-heading" class="section-title">On Instagram</h2>
			</div>
			<a
				href={IG_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="handle"
			>
				<span class="ig-icon" aria-hidden="true">◉</span>
				@{IG_HANDLE}
			</a>
		</header>

		<div class="grid">
			{
				IG_TILES.map((src) => (
					<a
						href={IG_URL}
						target="_blank"
						rel="noopener noreferrer"
						class="tile"
						aria-label={`View @${IG_HANDLE} on Instagram`}
					>
						<img
							src={src}
							alt=""
							loading="lazy"
							decoding="async"
						/>
						<div class="tile-overlay" aria-hidden="true">
							<span class="overlay-icon">◉</span>
						</div>
					</a>
				))
			}
		</div>

		<p class="footnote">
			A glimpse of the most recent posts. The full feed lives on
			<a
				href={IG_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="footnote-link">@{IG_HANDLE}</a
			>.
		</p>
	</div>
</section>

<style>
	.ig {
		background: var(--rp-cream);
	}

	.container {
		max-width: var(--rp-page-max);
		margin: 0 auto;
		padding: 64px 24px 64px;
	}

	.section-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 24px;
	}

	.eyebrow {
		font-family: var(--rp-font-body);
		font-size: var(--rp-size-tiny);
		letter-spacing: var(--rp-track-eyebrow);
		text-transform: uppercase;
		color: var(--rp-muted);
		margin: 0 0 6px;
	}

	.section-title {
		font-family: var(--rp-font-display);
		font-weight: 400;
		font-size: 28px;
		color: var(--rp-ink);
		margin: 0;
	}

	.handle {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-family: var(--rp-font-body);
		font-size: 14px;
		color: var(--rp-sage);
		text-decoration: none;
		white-space: nowrap;
	}
	.handle:hover {
		text-decoration: underline;
	}
	.ig-icon {
		font-size: 16px;
		line-height: 1;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 8px;
	}

	.tile {
		position: relative;
		display: block;
		width: 100%;
		padding-bottom: 100%;
		overflow: hidden;
		background: var(--rp-sage-soft);
		text-decoration: none;
	}
	.tile img {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition:
			transform 0.5s ease,
			filter 0.4s ease;
	}

	.tile-overlay {
		position: absolute;
		inset: 0;
		background: rgba(74, 103, 65, 0);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition:
			background 0.3s ease,
			opacity 0.3s ease;
		pointer-events: none;
	}
	.overlay-icon {
		color: var(--rp-cream);
		font-size: 28px;
		line-height: 1;
		filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
	}

	.tile:hover img {
		transform: scale(1.06);
		filter: brightness(0.78);
	}
	.tile:hover .tile-overlay {
		opacity: 1;
		background: rgba(74, 103, 65, 0.25);
	}
	.tile:focus-visible {
		outline: 2px solid var(--rp-sage);
		outline-offset: 2px;
	}

	.footnote {
		font-family: var(--rp-font-body);
		font-size: 13px;
		color: var(--rp-muted);
		text-align: center;
		margin: 28px 0 0;
		font-style: italic;
	}
	.footnote-link {
		color: var(--rp-sage);
		font-style: normal;
		text-decoration: none;
	}
	.footnote-link:hover {
		text-decoration: underline;
	}

	@media (max-width: 800px) {
		.container {
			padding: 48px 18px 48px;
		}
		.section-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 8px;
			margin-bottom: 20px;
		}
		.grid {
			grid-template-columns: repeat(3, 1fr);
		}
		.section-title {
			font-size: 24px;
		}
		.overlay-icon {
			font-size: 24px;
		}
	}
</style>
