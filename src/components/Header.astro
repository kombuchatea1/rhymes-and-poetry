---
/* ===========================================================================
 * src/components/Header.astro
 * Rhymes & Poetry — site header (logo + nav + Subscribe pill)
 *
 * WHAT AN .ASTRO FILE IS
 * ----------------------
 * Three regions, top to bottom:
 *   1. Frontmatter — between the --- delimiters at the top. Plain JavaScript
 *      that runs at BUILD TIME on the server, not in the browser. Use it for
 *      imports, data fetching, computed props.
 *   2. Template — HTML-like markup with {expression} interpolation. Renders
 *      to plain HTML at build time.
 *   3. <style> block — CSS scoped to this component. Astro adds a unique
 *      class hash at build time so styles don't leak to other components.
 *
 * WHY THIS MATTERS (Push tie-in)
 * ------------------------------
 * Astro's default mode is "ship as much HTML as possible, ship as little JS
 * as possible." This component renders to ~30 lines of static HTML at build
 * time — no JavaScript reaches the browser unless we explicitly opt in with
 * `client:load` or similar directives. Smaller attack surface than SPAs:
 * no hydration, no framework bundle, no client-side routing logic. Same
 * principle as preferring server-rendered to client-rendered for the parts
 * of your app that don't need interactivity — fewer moving parts, fewer
 * places for things to go wrong.
 * ========================================================================= */

const navItems = [
	{ label: "Home", href: "/" },
	{ label: "Topics", href: "/topics" },
	{ label: "About", href: "/about" },
	{ label: "Blog", href: "/blog" },
];
---

<header class="site-header">
	<div class="container">
		<a href="/" class="brand" aria-label="Rhymes & Poetry — home">
			<span class="mark" aria-hidden="true">R&amp;P</span>
			<span class="wordmark">Rhymes &amp; Poetry</span>
		</a>

		<nav class="nav" aria-label="Primary">
			{
				navItems.map((item) => (
					<a href={item.href} class="nav-link">
						{item.label}
					</a>
				))
			}
			<a href="/subscribe" class="subscribe-pill">Subscribe</a>
		</nav>
	</div>
</header>

<style>
	/* All selectors below are auto-scoped to this component by Astro at build
     time. Astro appends a unique data-attribute hash to each element, so
     `.site-header` here can never collide with a `.site-header` elsewhere.
     This is build-time CSS scoping — different mechanism from Shadow DOM
     (runtime) but achieves similar component isolation. */

	.site-header {
		background: var(--rp-cream);
		border-bottom: 1px solid rgba(0, 0, 0, 0.06);
	}

	.container {
		max-width: var(--rp-page-max);
		margin: 0 auto;
		padding: 18px 24px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}

	/* Brand (logo + wordmark) — pure CSS, no image asset.
     The mark is a sage circle with italic R&P text inside it.
     Scales perfectly at any size, easy to recolor via CSS variables. */
	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		color: var(--rp-ink);
	}
	.brand:hover {
		text-decoration: none;
	}
	.mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: 50%;
		background: var(--rp-sage);
		color: var(--rp-cream);
		font-family: var(--rp-font-display);
		font-style: italic;
		font-size: 13px;
		font-weight: 400;
		line-height: 1;
		letter-spacing: -0.02em;
		flex-shrink: 0;
	}
	.wordmark {
		font-family: var(--rp-font-display);
		font-size: 18px;
		color: var(--rp-ink);
		line-height: 1;
	}

	/* Navigation */
	.nav {
		display: flex;
		align-items: center;
		gap: 22px;
	}
	.nav-link {
		font-family: var(--rp-font-body);
		font-size: 14px;
		color: var(--rp-ink);
		text-decoration: none;
		padding: 4px 0;
		border-bottom: 1px solid transparent;
		transition: border-color 0.15s ease;
	}
	.nav-link:hover {
		text-decoration: none;
		border-bottom-color: var(--rp-ink);
	}

	/* Subscribe pill — visually distinct from nav links so it reads as a CTA */
	.subscribe-pill {
		display: inline-block;
		padding: 6px 16px;
		border: 1px solid var(--rp-sage);
		border-radius: var(--rp-radius-pill);
		color: var(--rp-sage);
		font-family: var(--rp-font-body);
		font-size: 13px;
		text-decoration: none;
		transition: background 0.15s ease, color 0.15s ease;
	}
	.subscribe-pill:hover {
		background: var(--rp-sage);
		color: var(--rp-cream);
		text-decoration: none;
	}

	/* Mobile: stack the nav vertically below the brand on narrow screens.
     For an MVP we keep it simple — no hamburger menu, just a vertical stack.
     If the brand grows long enough we'll add a proper toggle later. */
	@media (max-width: 600px) {
		.container {
			flex-direction: column;
			align-items: center;
			gap: 14px;
			padding: 16px 18px;
		}
		.brand {
			justify-content: center;
		}
		.nav {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
			gap: 16px;
		}
		.wordmark {
			font-size: 16px;
		}
	}
</style>
