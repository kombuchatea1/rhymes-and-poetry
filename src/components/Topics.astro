---
/* ===========================================================================
 * src/components/Topics.astro
 * Rhymes & Poetry — "Browse by topic" section (5 circular counters)
 *
 * Counts are computed at build time from the content collection by
 * filtering posts where data.category matches each topic's slug.
 * The slugs here MUST match the enum in content.config.ts — keep in sync.
 * ========================================================================= */

import { getCollection } from "astro:content";
import { TOPIC_DEFS } from "../consts/topics";

const posts = await getCollection("blog");
const topics = TOPIC_DEFS.map((t) => ({
    ...t,
    count: posts.filter((p) => p.data.category === t.slug).length,
}));

// Format counts with leading zero for visual rhythm — 18, 24, 09, 12, 07
const fmtCount = (n: number) => String(n).padStart(2, "0");
---

<section class="topics" aria-labelledby="topics-heading">
    <div class="container">
        <h2 id="topics-heading" class="section-title">Browse by topic</h2>

        <div class="grid">
            {
                topics.map((topic) => (
                    <a
                        href={`/topics/${topic.slug}`}
                        class="topic"
                        aria-label={`${topic.label} — ${topic.count} posts`}
                    >
                        <div class="circle">
                            <span class="count">{fmtCount(topic.count)}</span>
                        </div>
                        <span class="label">{topic.label}</span>
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .topics {
        background: var(--rp-cream-warm);
        /* Subtle decorative top + bottom hairline gives the section
       a contained "card" feeling within the page flow */
        border-top: 1px solid rgba(74, 103, 65, 0.08);
        border-bottom: 1px solid rgba(74, 103, 65, 0.08);
    }

    .container {
        max-width: var(--rp-page-max);
        margin: 0 auto;
        padding: 56px 24px 64px;
    }

    .section-title {
        font-family: var(--rp-font-display);
        font-weight: 400;
        font-size: 28px;
        color: var(--rp-ink);
        text-align: center;
        margin: 0 0 36px;
    }

    /* ===== Topic grid ===== */

    .grid {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 28px;
        flex-wrap: wrap;
        /* flex-wrap lets the row break to 2 lines on narrow screens
       without us writing explicit media queries — the 5 circles
       will reflow naturally */
    }

    .topic {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--rp-ink);
        /* Each topic is a single click target — circle + label together */
    }
    .topic:hover {
        text-decoration: none;
    }

    .circle {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        background: var(--rp-cream);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s ease, transform 0.2s ease;
    }

    .count {
        font-family: var(--rp-font-display);
        font-weight: 400;
        font-size: 24px;
        color: var(--rp-sage);
        line-height: 1;
        transition: color 0.2s ease;
    }

    .label {
        font-family: var(--rp-font-body);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--rp-muted);
        text-align: center;
        transition: color 0.15s ease;
    }

    /* Hover: circle fills with sage, count turns cream, label darkens.
     The whole thing feels like it lights up. */
    .topic:hover .circle {
        background: var(--rp-sage);
        transform: translateY(-2px);
    }
    .topic:hover .count {
        color: var(--rp-cream);
    }
    .topic:hover .label {
        color: var(--rp-ink);
    }

    /* ===== Mobile: smaller circles, tighter gap ===== */

    @media (max-width: 600px) {
        .container {
            padding: 40px 18px 48px;
        }
        .section-title {
            font-size: 24px;
            margin-bottom: 28px;
        }
        .grid {
            gap: 18px;
        }
        .circle {
            width: 70px;
            height: 70px;
        }
        .count {
            font-size: 20px;
        }
        .label {
            font-size: 10px;
            letter-spacing: 0.12em;
        }
    }
</style>
