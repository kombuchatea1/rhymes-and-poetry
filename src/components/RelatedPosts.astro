---
/* ===========================================================================
 * src/components/RelatedPosts.astro
 * Rhymes & Poetry — tag-based related posts module
 *
 * Shown at the bottom of each blog post. Displays up to 3 posts that share
 * at least one tag with the current post, ranked by number of shared tags.
 * Hidden entirely if no related posts are found (e.g. post has no tags yet).
 * ========================================================================= */

import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <aside class="related">
    <div class="related-inner">
      <p class="related-eyebrow">More to read</p>
      <div class="related-grid">
        {posts.map((post) => (
          <article class="related-card">
            <a href={`/blog/${post.id}/`} class="related-link">
              <div class="related-image">
                {post.data.heroImage ? (
                  <img
                    src={post.data.heroImage}
                    alt={post.data.heroImageAlt ?? ''}
                    decoding="async"
                    loading="lazy"
                  />
                ) : (
                  <div class="related-placeholder" />
                )}
              </div>
              <div class="related-body">
                <p class="related-meta">
                  <FormattedDate date={post.data.pubDate} />
                </p>
                <h3 class="related-title">{post.data.title}</h3>
                {post.data.description && (
                  <p class="related-excerpt">{post.data.description}</p>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </aside>
)}

<style>
  .related {
    border-top: 1px solid var(--rp-sage);
    margin-top: 72px;
    padding-top: 32px;
    padding-bottom: 64px;
  }

  .related-inner {
    max-width: var(--rp-content-max);
    margin: 0 auto;
  }

  .related-eyebrow {
    font-family: var(--rp-font-body);
    font-size: var(--rp-size-tiny);
    letter-spacing: var(--rp-track-eyebrow);
    text-transform: uppercase;
    color: var(--rp-muted);
    margin: 0 0 28px;
    text-align: center;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .related-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .related-image {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    margin-bottom: 14px;
    overflow: hidden;
    background: var(--rp-sage-soft);
  }

  .related-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .related-link:hover .related-image img {
    transform: scale(1.03);
  }

  .related-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--rp-sage-soft);
  }

  .related-meta {
    font-family: var(--rp-font-body);
    font-size: var(--rp-size-tiny);
    letter-spacing: var(--rp-track-eyebrow);
    text-transform: uppercase;
    color: var(--rp-muted);
    margin: 0 0 6px;
  }

  .related-title {
    font-family: var(--rp-font-display);
    font-weight: 400;
    font-size: 20px;
    line-height: 1.25;
    color: var(--rp-ink);
    margin: 0 0 8px;
    transition: color 0.15s ease;
  }

  .related-link:hover .related-title {
    color: var(--rp-sage);
  }

  .related-excerpt {
    font-family: var(--rp-font-body);
    font-size: 14px;
    line-height: 1.5;
    color: var(--rp-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 700px) {
    .related-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .related-title {
      font-size: 18px;
    }
  }
</style>
