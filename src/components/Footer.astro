---
/* ===========================================================================
 * src/components/Footer.astro
 * Rhymes & Poetry — minimal site footer (two lines)
 *
 * Layout:
 *   Row 1: brand mark + wordmark on left, 3 text links on right
 *   Row 2: hairline + © Rhymes & Poetry centered
 *
 * About 80-90px tall total. Quiet on purpose — the rest of the site
 * already does the talking; the footer just confirms the brand and
 * gives the visitor a few escape hatches.
 *
 * Why minimal beats the typical 3-column pattern here:
 * The standard "Explore / Connect / About / Newsletter" footer is great
 * for sites with deep architecture — software products, news sites with
 * 50 categories, marketing sites with multiple funnels. For a personal
 * editorial brand with five real destinations (Home, Topics, About,
 * Blog, Subscribe — most of which are already in the header), the
 * 3-column footer adds visual weight without functional value. The
 * minimal version respects the reader's attention.
 * ========================================================================= */

const currentYear = new Date().getFullYear();

const links = [
	{
		label: "Instagram",
		href: "https://www.instagram.com/rhymesandpoetry_jtc/",
		external: true,
	},
	{ label: "Subscribe", href: "/#subscribe", external: false },
	{ label: "About", href: "/about", external: false },
];
---

<footer class="site-footer">
	<div class="container">
		<div class="row">
			<a href="/" class="brand" aria-label="Rhymes & Poetry — home">
				<span class="mark" aria-hidden="true">R&amp;P</span>
				<span class="wordmark">Rhymes &amp; Poetry</span>
			</a>

			<nav class="links" aria-label="Footer">
				{
					links.map((link) =>
						link.external ? (
							<a
								href={link.href}
								target="_blank"
								rel="noopener noreferrer"
							>
								{link.label}
							</a>
						) : (
							<a href={link.href}>{link.label}</a>
						)
					)
				}
			</nav>
		</div>

		<div class="bar">
			<span>&copy; {currentYear} Rhymes &amp; Poetry</span>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--rp-cream);
	}

	.container {
		max-width: var(--rp-page-max);
		margin: 0 auto;
		padding: 24px 24px 28px;
	}

	.row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		flex-wrap: wrap;
	}

	/* ===== Brand (mark + wordmark) ===== */

	.brand {
		display: flex;
		align-items: center;
		gap: 8px;
		text-decoration: none;
		color: var(--rp-ink);
	}
	.brand:hover {
		text-decoration: none;
	}
	.mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		border-radius: 50%;
		background: var(--rp-sage);
		color: var(--rp-cream);
		font-family: var(--rp-font-display);
		font-style: italic;
		font-size: 11px;
		font-weight: 400;
		line-height: 1;
		letter-spacing: -0.02em;
		flex-shrink: 0;
	}
	.wordmark {
		font-family: var(--rp-font-display);
		font-size: 14px;
		color: var(--rp-ink);
		line-height: 1;
	}

	/* ===== Inline links ===== */

	.links {
		display: flex;
		gap: 22px;
	}
	.links a {
		font-family: var(--rp-font-body);
		font-size: 13px;
		color: var(--rp-muted);
		text-decoration: none;
		transition: color 0.15s ease;
	}
	.links a:hover {
		color: var(--rp-sage);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 2px;
	}

	/* ===== Bottom copyright bar ===== */

	.bar {
		border-top: 1px solid rgba(0, 0, 0, 0.06);
		margin-top: 18px;
		padding-top: 16px;
		text-align: center;
		font-family: var(--rp-font-body);
		font-size: 12px;
		color: var(--rp-muted);
	}

	/* ===== Mobile ===== */

	@media (max-width: 600px) {
		.container {
			padding: 20px 18px 24px;
		}
		.row {
			flex-direction: column;
			align-items: center;
			gap: 14px;
			text-align: center;
		}
		.links {
			gap: 18px;
		}
	}
</style>
