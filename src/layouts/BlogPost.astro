---
/* ===========================================================================
 * src/layouts/BlogPost.astro
 * Rhymes & Poetry — editorial post layout
 *
 * Wraps every blog post (Markdown file in src/content/blog/). Renders:
 *   - Site header
 *   - Optional hero image
 *   - Editorial post header (date + title + optional deck)
 *   - Markdown body in editorial prose styling
 *   - Optional Instagram source pill (when post has ig_shortcode frontmatter)
 *   - Subscribe block (every post is a conversion opportunity)
 *   - Site footer
 *
 * COMPARED TO THE WIX EDITORIAL-POST.JS CUSTOM ELEMENT
 * ----------------------------------------------------
 * The Wix version had to scrape rendered DOM at runtime — read Wix-rendered
 * post elements via [data-hook="..."] selectors, then re-render into a
 * Shadow DOM. Lots of ceremony to escape the platform.
 *
 * Here, we have the Markdown content directly via Astro's content collection
 * at build time. We compose it through a layout. Server-side, statically
 * generated, no client-side DOM walking. Same visual result, fraction of
 * the complexity.
 *
 * This is the value of owning the rendering pipeline. Every workaround
 * we wrote for Wix is now unnecessary.
 *
 * POEM-BLOCK PATTERN
 * ------------------
 * For poems, wrap them in markdown like this:
 *
 *   <div class="poem-block">
 *
 *   *Line one*
 *
 *   *Line two*
 *
 *   *Line three*
 *
 *   </div>
 *
 * The italic stanza inside renders as a centered Playfair italic block on
 * a white card with sage hairlines above and below. Manual wrapping (vs
 * auto-detect) keeps you in control: not every italic paragraph is a poem.
 *
 * IG SOURCE PILL
 * --------------
 * Add `ig_shortcode: "DL2rYpSsyQT"` to a post's frontmatter and the pill
 * appears at the bottom linking to the IG post. Requires the schema in
 * src/content.config.ts to include `ig_shortcode: z.string().optional()`
 * — see the deployment notes below the file.
 * ========================================================================= */

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Subscribe from "../components/Subscribe.astro";
import FormattedDate from "../components/FormattedDate.astro";

const { title, description, pubDate, updatedDate, heroImage, ig_shortcode } =
	Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<main>
			<article class="post">
				{
					heroImage && (
						<div class="post-hero">
							<img src={heroImage.src || heroImage} alt="" />
						</div>
					)
				}

				<header class="post-header">
					<p class="post-eyebrow">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									{" "}
									· Updated{" "}
									<FormattedDate date={updatedDate} />
								</span>
							)
						}
					</p>
					<h1 class="post-title">{title}</h1>
					{description && <p class="post-deck">{description}</p>}
				</header>

				<div class="post-body">
					<slot />
				</div>

				{
					ig_shortcode && (
						<div class="ig-source">
							<a
								href={`https://www.instagram.com/p/${ig_shortcode}/`}
								target="_blank"
								rel="noopener noreferrer"
							>
								Originally posted on Instagram
							</a>
						</div>
					)
				}
			</article>
		</main>

		<Subscribe />
		<Footer />
		<style>
			/* ===== Layout — scoped to this component ===== */

			.post {
				max-width: var(--rp-content-max);
				margin: 0 auto;
				padding: 64px 24px 80px;
			}

			.post-hero {
				margin-bottom: 40px;
				/* Cinematic 2:1 aspect ratio — Train Dreams influence.
				   overflow: hidden contains the Ken Burns scaled image. */
				aspect-ratio: 2 / 1;
				overflow: hidden;
				position: relative;

				/* Torn-paper edges via PNG mask in /public.
				   Mask is sized exactly 1:1 with the element so all four
				   tear edges (top, right, bottom, left) land exactly at
				   the element boundaries and are fully visible. */
				mask-image: url("/torn-paper-mask.png");
				-webkit-mask-image: url("/torn-paper-mask.png");
				mask-size: 100% 100%;
				-webkit-mask-size: 100% 100%;
				mask-repeat: no-repeat;
				-webkit-mask-repeat: no-repeat;
				mask-position: 0 0;
				-webkit-mask-position: 0 0;
				mask-mode: alpha;
				-webkit-mask-mode: alpha;

				/* Soft sage drop-shadow that follows the torn outline
				   (drop-shadow respects mask alpha — box-shadow would
				   only follow the rectangular bounds). */
				filter: drop-shadow(0 2px 10px rgba(74, 103, 65, 0.12));
			}

			/* Animation will be added in a separate pass — see notes. */
			.post-hero img {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: cover;
				transform-origin: center center;

				/* Two simultaneous animations on the image:
				   1. Ken Burns slow zoom (transform): cinematic camera move
				   2. Atmosphere (filter): the light/color "breathes"
				      via tiny oscillations in brightness, saturation, and
				      hue. Each oscillation is too small to notice in any
				      single moment, but combined and over time, the scene
				      feels alive — like the air is moving, the sun is
				      shifting, the moment is happening rather than being
				      a frozen photograph.

				   Different periods (24s and 22s) ensure they never
				   synchronize — gives organic feel rather than pulsed. */
				animation:
					rp-ken-burns 24s ease-in-out infinite alternate,
					rp-atmosphere 22s ease-in-out infinite;
			}

			@keyframes rp-ken-burns {
				0% {
					transform: scale(1) translate(0, 0);
				}
				100% {
					transform: scale(1.06) translate(-1%, 1%);
				}
			}

			@keyframes rp-atmosphere {
				/* Brightness ±2%, saturation ±3%, hue ±2deg. All within
				   the threshold of "feels alive" rather than "obviously
				   shifting." The image always returns to its true state
				   at 0% and 100% so the loop is invisible. */
				0% {
					filter: brightness(0.98) saturate(0.97) hue-rotate(0deg);
				}
				50% {
					filter: brightness(1.02) saturate(1.04) hue-rotate(2deg);
				}
				100% {
					filter: brightness(0.98) saturate(0.97) hue-rotate(0deg);
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.post-hero img {
					animation: none;
				}
			}

			/* Respect users who prefer reduced motion (accessibility) */
			@media (prefers-reduced-motion: reduce) {
				.post-hero img {
					animation: none;
				}
			}

			.post-header {
				text-align: center;
				margin-bottom: 48px;
			}

			.post-eyebrow {
				font-family: var(--rp-font-body);
				font-size: var(--rp-size-tiny);
				letter-spacing: var(--rp-track-eyebrow);
				text-transform: uppercase;
				color: var(--rp-muted);
				margin: 0 0 18px;
			}
			.updated {
				font-style: italic;
			}

			.post-title {
				font-family: var(--rp-font-display);
				font-weight: 400;
				font-size: 44px;
				line-height: 1.1;
				color: var(--rp-ink);
				margin: 0;
				letter-spacing: -0.015em;
			}

			.post-deck {
				font-family: var(--rp-font-display);
				font-style: italic;
				font-size: 20px;
				color: var(--rp-muted);
				margin: 16px auto 0;
				max-width: 520px;
				line-height: 1.4;
			}

			.post-body {
				font-family: var(--rp-font-body);
				font-size: var(--rp-size-body);
				line-height: 1.75;
				color: var(--rp-ink);
			}

			/* ===== IG source pill ===== */

			.ig-source {
				text-align: center;
				margin: 64px 0 0;
			}
			.ig-source a {
				display: inline-block;
				padding: 9px 20px;
				border: 1px solid var(--rp-sage);
				border-radius: var(--rp-radius-pill);
				font-family: var(--rp-font-body);
				font-size: 12px;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--rp-sage);
				text-decoration: none;
				transition: background 0.2s ease, color 0.2s ease;
			}
			.ig-source a:hover {
				background: var(--rp-sage);
				color: var(--rp-cream);
				text-decoration: none;
			}

			/* ===== Mobile ===== */

			@media (max-width: 700px) {
				.post {
					padding: 48px 18px 64px;
				}
				.post-title {
					font-size: 32px;
				}
				.post-deck {
					font-size: 17px;
				}
				.post-body {
					font-size: 17px;
				}
			}
		</style>

		<style is:global>
			/* ===== Prose styles — global so they reach Markdown-rendered content =====
     Astro's scoped CSS doesn't apply to elements rendered via <slot />
     because the slot content has different scoping hashes. We use
     `is:global` here to opt the prose rules out of scoping, then key
     them on .post-body so they only apply within posts. */

			.post-body p {
				margin: 0 0 1.4em;
			}

			/* Drop cap on first paragraph (not on paragraphs inside .poem-block).
     Browser ::first-letter selects the first character of the first line —
     editorial typography classic. */
			.post-body > p:first-of-type::first-letter {
				font-family: var(--rp-font-display);
				font-weight: 400;
				font-size: 64px;
				line-height: 0.9;
				float: left;
				padding: 6px 12px 0 0;
				color: var(--rp-sage);
			}

			/* Headings inside body */
			.post-body h2 {
				font-family: var(--rp-font-display);
				font-size: 28px;
				font-weight: 400;
				margin: 1.8em 0 0.6em;
				color: var(--rp-ink);
				line-height: 1.25;
			}
			.post-body h3 {
				font-family: var(--rp-font-display);
				font-size: 22px;
				font-weight: 400;
				margin: 1.4em 0 0.5em;
				color: var(--rp-ink);
			}

			/* Sage-rule blockquote */
			.post-body blockquote {
				border-left: 3px solid var(--rp-sage);
				margin: 2em 0;
				padding: 0.4em 0 0.4em 1.4em;
				font-family: var(--rp-font-display);
				font-style: italic;
				font-size: 20px;
				line-height: 1.45;
				color: var(--rp-muted);
			}
			.post-body blockquote p {
				margin: 0 0 0.5em;
			}
			.post-body blockquote p:last-child {
				margin-bottom: 0;
			}

			/* Inline emphasis */
			.post-body em,
			.post-body i {
				font-style: italic;
			}
			.post-body strong,
			.post-body b {
				font-weight: 600;
			}

			/* Code (inline) */
			.post-body code {
				font-family: var(--rp-font-mono);
				font-size: 0.9em;
				background: var(--rp-cream-warm);
				padding: 1px 6px;
				border-radius: 3px;
			}

			/* ===== SIGNATURE =====
     Dinkus (centered three-dot ornament) + author initials in Playfair italic
     sage. Editorial convention — marks a clean break between the post and
     the metadata that follows.

     Usage in markdown:
       <div class="signature">

       — JTC

       </div>
  */
			.post-body .signature {
				text-align: center;
				margin-top: 3.5em;
				padding-top: 36px;
				font-family: var(--rp-font-display);
				font-style: italic;
				color: var(--rp-sage);
				font-size: 18px;
				letter-spacing: 0.02em;
				position: relative;
			}
			.post-body .signature::before {
				content: "· · ·";
				display: block;
				text-align: center;
				color: var(--rp-sage-line);
				letter-spacing: 0.65em;
				font-size: 16px;
				margin-bottom: 28px;
				/* compensate for letter-spacing pushing visual center off */
				padding-left: 0.65em;
			}
			.post-body .signature p {
				margin: 0;
			}

			/* ===== POEM BLOCK =====
     Wrap a poem in markdown with:
       <div class="poem-block">
       *line one*
       *line two*
       </div>
 
     The wrapper renders as a white card with sage hairlines above and
     below; italic stanza inside renders as centered Playfair italic. */

			.post-body .poem-block {
				background: var(--rp-white);
				padding: 44px 32px;
				margin: 44px 0;
				text-align: center;
				border: 1px solid rgba(0, 0, 0, 0.04);
			}
			.post-body .poem-block::before,
			.post-body .poem-block::after {
				content: "";
				display: block;
				height: 1px;
				background: var(--rp-sage);
				width: 96px;
				margin: 0 auto;
			}
			.post-body .poem-block::before {
				margin-bottom: 28px;
			}
			.post-body .poem-block::after {
				margin-top: 28px;
			}

			.post-body .poem-block p {
				font-family: var(--rp-font-display);
				font-style: italic;
				font-weight: 400;
				font-size: 22px;
				line-height: 1.65;
				margin: 0 0 0.5em;
				color: var(--rp-ink);
			}
			.post-body .poem-block p:last-child {
				margin-bottom: 0;
			}
			.post-body .poem-block em {
				font-style: italic;
			}

			/* Mobile drop cap + poem block adjustments */
			@media (max-width: 700px) {
				.post-body > p:first-of-type::first-letter {
					font-size: 52px;
				}
				.post-body .poem-block {
					padding: 32px 22px;
					margin: 32px 0;
				}
				.post-body .poem-block p {
					font-size: 20px;
				}
				.post-body blockquote {
					font-size: 18px;
				}
			}
		</style>
	</body>
</html>
