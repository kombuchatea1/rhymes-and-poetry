---
/* ===========================================================================
 * src/pages/topics/[slug].astro
 * Rhymes & Poetry — Individual topic page
 *
 * Dynamic route. One page per category. Lists posts filtered to that
 * category, with editorial header and same card grid as /blog index.
 * If a category has no posts yet, shows a graceful empty state.
 * ========================================================================= */

import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { TOPIC_DEFS } from "../../consts/topics";

export async function getStaticPaths() {
	// IMPORTANT: TOPIC_DEFS must be IMPORTED here, not declared as a
	// top-level const in this file. Astro's getStaticPaths runs in an
	// isolated execution context that doesn't see same-file frontmatter
	// constants — but it CAN see imports from other modules.
	const { TOPIC_DEFS } = await import("../../consts/topics");
	return TOPIC_DEFS.map((t) => ({
		params: { slug: t.slug },
		props: { label: t.label, desc: t.desc },
	}));
}

const { slug } = Astro.params;
const { label, desc } = Astro.props;

const allPosts = await getCollection("blog");
const posts = allPosts
	.filter((p) => p.data.category === slug)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const PAGE_TITLE = `${label} — Rhymes & Poetry`;
const PAGE_DESC = desc;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={PAGE_TITLE} description={PAGE_DESC} />
	</head>
	<body>
		<Header />

		<main>
			<article class="topic">
				<header class="topic-header">
					<p class="eyebrow">
						<a href="/topics/" class="back">← All topics</a>
					</p>
					<h1 class="title">{label}</h1>
					<p class="deck">{desc}</p>
					<p class="count">
						{posts.length}{" "}
						{posts.length === 1 ? "piece" : "pieces"}
					</p>
				</header>

				{
					posts.length > 0 ? (
						<div class="grid">
							{posts.map((post) => (
								<article class="card">
									<a
										href={`/blog/${post.id}/`}
										class="card-link"
									>
										<div class="card-image">
											{post.data.heroImage ? (
												<Image
													src={post.data.heroImage}
													alt=""
													widths={[400, 600, 800]}
													sizes="(max-width: 600px) 95vw, (max-width: 1000px) 45vw, 600px"
													decoding="async"
												/>
											) : (
												<div class="card-placeholder" />
											)}
										</div>
										<div class="card-body">
											<p class="card-meta">
												<FormattedDate
													date={post.data.pubDate}
												/>
											</p>
											<h2 class="card-title">
												{post.data.title}
											</h2>
											{post.data.description && (
												<p class="card-excerpt">
													{post.data.description}
												</p>
											)}
										</div>
									</a>
								</article>
							))}
						</div>
					) : (
						<div class="empty">
							<p class="empty-msg">
								No pieces in this topic yet. The category
								exists, the work is coming.
							</p>
							<a href="/blog/" class="empty-cta">
								Browse all posts →
							</a>
						</div>
					)
				}
			</article>
		</main>

		<Footer />

		<style>
			.topic {
				max-width: var(--rp-page-max);
				margin: 0 auto;
				padding: 64px 24px 96px;
			}

			.topic-header {
				text-align: center;
				margin-bottom: 56px;
			}

			.eyebrow {
				font-family: var(--rp-font-body);
				font-size: var(--rp-size-tiny);
				letter-spacing: var(--rp-track-eyebrow);
				text-transform: uppercase;
				color: var(--rp-muted);
				margin: 0 0 16px;
			}

			.back {
				color: var(--rp-muted);
				text-decoration: none;
				transition: color 0.15s ease;
			}
			.back:hover {
				color: var(--rp-sage);
				text-decoration: none;
			}

			.title {
				font-family: var(--rp-font-display);
				font-weight: 400;
				font-size: 48px;
				line-height: 1.1;
				color: var(--rp-ink);
				margin: 0 0 14px;
				letter-spacing: -0.015em;
			}

			.deck {
				font-family: var(--rp-font-display);
				font-style: italic;
				font-size: 19px;
				color: var(--rp-muted);
				line-height: 1.5;
				margin: 0 auto 14px;
				max-width: 540px;
			}

			.count {
				font-family: var(--rp-font-body);
				font-size: 13px;
				letter-spacing: var(--rp-track-eyebrow);
				text-transform: uppercase;
				color: var(--rp-faint);
				margin: 0;
			}

			/* ===== Grid (mirrors /blog index) ===== */

			.grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 40px 28px;
			}

			.card-link {
				display: block;
				color: inherit;
				text-decoration: none;
			}
			.card-link:hover {
				text-decoration: none;
			}

			/* padding-bottom hack — same reliability fix as /blog index */
			.card-image {
				position: relative;
				width: 100%;
				padding-bottom: 56.25%; /* 16:9 */
				margin-bottom: 18px;
				overflow: hidden;
				background: var(--rp-sage-soft);
			}
			.card-image img {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				transition: transform 0.4s ease;
			}
			.card-link:hover .card-image img {
				transform: scale(1.03);
			}

			.card-placeholder {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: var(--rp-sage-soft);
			}
			.card:nth-child(2n) .card-placeholder {
				background: var(--rp-cream-warm);
			}

			.card-meta {
				font-family: var(--rp-font-body);
				font-size: var(--rp-size-tiny);
				letter-spacing: var(--rp-track-eyebrow);
				text-transform: uppercase;
				color: var(--rp-muted);
				margin: 0 0 8px;
			}

			.card-title {
				font-family: var(--rp-font-display);
				font-weight: 400;
				font-size: 24px;
				line-height: 1.2;
				color: var(--rp-ink);
				margin: 0 0 10px;
				transition: color 0.15s ease;
			}
			.card-link:hover .card-title {
				color: var(--rp-sage);
			}

			.card-excerpt {
				font-family: var(--rp-font-body);
				font-size: 15px;
				line-height: 1.55;
				color: var(--rp-muted);
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* ===== Empty state ===== */

			.empty {
				text-align: center;
				padding: 48px 0;
				font-family: var(--rp-font-body);
			}
			.empty-msg {
				font-style: italic;
				color: var(--rp-muted);
				font-size: 17px;
				margin: 0 0 18px;
			}
			.empty-cta {
				color: var(--rp-sage);
				font-size: 14px;
				letter-spacing: 0.06em;
			}

			/* ===== Mobile ===== */

			@media (max-width: 800px) {
				.topic {
					padding: 48px 18px 72px;
				}
				.title {
					font-size: 36px;
				}
				.deck {
					font-size: 17px;
				}
				.grid {
					grid-template-columns: 1fr;
					gap: 32px;
				}
			}
		</style>
	</body>
</html>
