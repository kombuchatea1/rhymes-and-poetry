---
/* ===========================================================================
 * src/pages/about.astro
 * Rhymes & Poetry — About page
 *
 * Editorial layout with its own structure (not using BlogPost.astro since
 * this isn't a post). Three sections:
 *   - Header (eyebrow + title + portrait placeholder)
 *   - Bio (the writer's story, voice, why this site exists)
 *   - CTA (subscribe + Instagram links)
 *
 * The bio copy is a thoughtful placeholder in the brand voice — edit
 * directly in this file to make it yours. The R&P circle stands in for
 * a portrait until you have one to drop in (replace the .portrait div
 * with an <img> referencing src/assets/about/portrait.jpg).
 * ========================================================================= */

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Subscribe from "../components/Subscribe.astro";

const PAGE_TITLE = "About — Rhymes & Poetry";
const PAGE_DESC =
	"The writer behind Rhymes & Poetry — Jake (JTC) on what he writes, why, and how this whole thing started.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={PAGE_TITLE} description={PAGE_DESC} />
	</head>

	<body>
		<Header />

		<main>
			<article class="about">
				<!-- Header -->
				<header class="about-header">
					<p class="eyebrow">The writer</p>
					<h1 class="title">Hi, I'm Jake.</h1>
					<p class="deck">
						JTC if you know me from Instagram. Writing rap, poetry,
						and the occasional honest sentence in between.
					</p>
				</header>

				<!-- Portrait placeholder -->
				<div class="portrait-frame">
					<div class="portrait" aria-hidden="true">
						<span class="portrait-mark">R&amp;P</span>
					</div>
					<p class="portrait-caption">
						<em>Portrait coming soon</em>
					</p>
				</div>

				<!-- Bio prose -->
				<div class="about-body">
					<p>
						I started writing poetry the way most people start —
						badly, in private, because something needed to come
						out. That was years ago. I kept doing it because
						somewhere along the way it stopped being a release
						and became a practice. A way of paying attention that
						I couldn't get from anywhere else.
					</p>

					<p>
						Some of what I write is rap — built for cadence, for
						bars, for that specific feeling when the line lands.
						Some of it is quieter — the kind of poem that earns
						its weight by sitting still. Most of it is somewhere
						in between.
					</p>

					<h2>Why this site exists</h2>

					<p>
						Instagram is a feed. It moves. By the time you've
						read a poem you cared about, the algorithm has
						buried it. This site is the opposite — a place
						where the work stays, gathers, gets the room it
						deserves. Easier to find old pieces. Easier to read
						them in the voice they were written in.
					</p>

					<p>
						My hope is that something here makes you feel a
						little less alone. That's it. That's the whole
						project. If a line lands and you save it, screenshot
						it, send it to someone — that's the work doing what
						it was meant to do.
					</p>

					<h2>What you'll find here</h2>

					<p>
						<strong>The journal</strong> — every poem I've
						published, most recent first. Searchable, organized
						by topic, written to be read on any device.
					</p>

					<p>
						<strong>The newsletter</strong> — twice a month, new
						verses delivered to your inbox. No spam, no padding,
						no sponsored anything. Just words.
					</p>

					<p>
						<strong>Instagram</strong> — daily and weekly drops
						at <a
							href="https://www.instagram.com/rhymesandpoetry_jtc/"
							target="_blank"
							rel="noopener noreferrer">@rhymesandpoetry_jtc</a
						>. The site is the long memory; Instagram is the
						current moment.
					</p>

					<p>Thank you for reading.</p>
				</div>

				<div class="signature">— JTC</div>
			</article>
		</main>

		<Subscribe />
		<Footer />

		<style>
			.about {
				max-width: var(--rp-content-max);
				margin: 0 auto;
				padding: 64px 24px 48px;
			}

			/* ===== Header ===== */

			.about-header {
				text-align: center;
				margin-bottom: 48px;
			}

			.eyebrow {
				font-family: var(--rp-font-body);
				font-size: var(--rp-size-tiny);
				letter-spacing: var(--rp-track-eyebrow);
				text-transform: uppercase;
				color: var(--rp-muted);
				margin: 0 0 16px;
			}

			.title {
				font-family: var(--rp-font-display);
				font-weight: 400;
				font-size: 48px;
				line-height: 1.1;
				color: var(--rp-ink);
				margin: 0 0 16px;
				letter-spacing: -0.015em;
			}

			.deck {
				font-family: var(--rp-font-display);
				font-style: italic;
				font-size: 20px;
				color: var(--rp-muted);
				line-height: 1.5;
				margin: 0 auto;
				max-width: 540px;
			}

			/* ===== Portrait ===== */

			.portrait-frame {
				text-align: center;
				margin: 0 0 56px;
			}

			.portrait {
				width: 180px;
				height: 180px;
				margin: 0 auto 14px;
				border-radius: 50%;
				background: var(--rp-sage);
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.portrait-mark {
				font-family: var(--rp-font-display);
				font-style: italic;
				font-size: 56px;
				color: var(--rp-cream);
				letter-spacing: -0.02em;
			}

			.portrait-caption {
				font-family: var(--rp-font-body);
				font-size: 13px;
				color: var(--rp-faint);
				margin: 0;
			}
			.portrait-caption em {
				font-style: italic;
			}

			/* ===== Bio body ===== */

			.about-body {
				font-family: var(--rp-font-body);
				font-size: var(--rp-size-body);
				line-height: 1.75;
				color: var(--rp-ink);
			}

			.about-body p {
				margin: 0 0 1.4em;
			}

			.about-body h2 {
				font-family: var(--rp-font-display);
				font-weight: 400;
				font-size: 28px;
				color: var(--rp-ink);
				line-height: 1.2;
				margin: 2.2em 0 0.6em;
			}

			.about-body strong {
				font-weight: 600;
				color: var(--rp-ink);
			}

			.about-body a {
				color: var(--rp-sage);
			}
			.about-body a:hover {
				text-decoration: underline;
				text-decoration-thickness: 1px;
				text-underline-offset: 2px;
			}

			/* ===== Signature ===== */

			.signature {
				text-align: center;
				margin-top: 3.5em;
				padding-top: 36px;
				font-family: var(--rp-font-display);
				font-style: italic;
				color: var(--rp-sage);
				font-size: 18px;
				letter-spacing: 0.02em;
				position: relative;
			}
			.signature::before {
				content: "· · ·";
				display: block;
				text-align: center;
				color: var(--rp-sage-line);
				letter-spacing: 0.65em;
				font-size: 16px;
				margin-bottom: 28px;
				padding-left: 0.65em;
			}

			/* ===== Mobile ===== */

			@media (max-width: 700px) {
				.about {
					padding: 48px 18px 40px;
				}
				.title {
					font-size: 36px;
				}
				.deck {
					font-size: 17px;
				}
				.about-body {
					font-size: 17px;
				}
				.about-body h2 {
					font-size: 24px;
				}
				.portrait {
					width: 140px;
					height: 140px;
				}
				.portrait-mark {
					font-size: 44px;
				}
			}
		</style>
	</body>
</html>
